FROM bitnami/spark:3.5.0

USER root

# Install Python packages
RUN apt-get update && apt-get install -y \
    python3-pip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    delta-spark==3.0.0 \
    pyspark==3.5.0 \
    pydantic>=2.0 \
    pyyaml \
    python-dotenv \
    psycopg2-binary \
    requests \
    structlog

WORKDIR /opt/dataforge

USER 1001
