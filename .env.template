# Docker Compose environment template
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airflow

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW_FERNET_KEY=Drmhze6EPcv0K0mn5fMZoSlBjnOORuyer4xwSuS3v0=

# DataForge Configuration
DATAFORGE_ENV=dev
DATAFORGE_VERSION=0.1.0

# Storage Configuration (Dev)
LAKEHOUSE_STORAGE_TYPE=minio
LAKEHOUSE_ENDPOINT=http://minio:9000
LAKEHOUSE_ACCESS_KEY=minioadmin
LAKEHOUSE_SECRET_KEY=minioadmin

# Storage Configuration (Production - Azure)
# LAKEHOUSE_STORAGE_TYPE=adls2
# LAKEHOUSE_ENDPOINT=https://{storage_account}.dfs.core.windows.net
# LAKEHOUSE_STORAGE_ACCOUNT={storage_account}
# LAKEHOUSE_STORAGE_KEY={storage_key}

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Logging Configuration
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=true

# Metrics Configuration
ENABLE_PROMETHEUS_METRICS=true
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_STREAMING=true
ENABLE_CDC=false
ENABLE_LINEAGE_TRACKING=true
